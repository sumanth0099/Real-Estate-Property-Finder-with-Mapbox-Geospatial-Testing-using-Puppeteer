# .env.example
# Copy this file to .env.test and fill in your values for testing
# For development, copy to .env.local and add your real Mapbox token

# Mapbox API Configuration
# For testing: use the mock token below
# For development: replace with your real Mapbox public access token from https://account.mapbox.com
MAPBOX_ACCESS_TOKEN=pk.test.mock-token-for-testing-purposes

# Mapbox Map Style
# See https://docs.mapbox.com/api/maps/styles/ for available styles
MAPBOX_STYLE=mapbox://styles/mapbox/streets-v11

# React App Environment Variables (used during build)
REACT_APP_MAPBOX_ACCESS_TOKEN=pk.test.mock-token-for-testing-purposes
REACT_APP_MAPBOX_STYLE=mapbox://styles/mapbox/streets-v11

# Application Port (default: 3006)
PORT=3006

# Test Configuration
APP_URL=http://localhost:3006
